<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.a762map">

    <!-- 网络 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- 定位（Android 6+ 需要运行时授权） -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <application
        android:name=".A762MapApp"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.A762Map">

        <!-- 高德 Key（来自 manifestPlaceholders） -->
        <meta-data
            android:name="com.amap.api.v2.apikey"
            android:value="${AMAP_API_KEY}" />

        <!-- 定位服务（AMapLocationClient 会用到） -->
        <service android:name="com.amap.api.location.APSService" />

        <!-- 启动入口：以 main 为准 -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- “我的”相关子页面：只保留你项目里确实存在的 Activity -->
        <activity
            android:name=".ui.profile.UserDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.profile.FootprintActivity"
            android:exported="false" />
        <activity
            android:name=".ui.profile.YearReportActivity"
            android:exported="false" />
        <activity
            android:name=".ui.profile.ExportPdfActivity"
            android:exported="false" />



    </application>
</manifest>
